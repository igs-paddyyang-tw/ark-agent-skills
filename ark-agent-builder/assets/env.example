# ── Telegram Bot（必填）──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token

# ── LLM 後端 ─────────────────────────────────────────────────
# Agent CLI 自動偵測：gemini → kiro → claude
GEMINI_API_KEY=your_key              # 選配：有就啟用 Gemini API 即時對話
GEMINI_CLI_CMD=gemini.cmd            # Windows: gemini.cmd / Linux: gemini

# ── OpenAI（選配）────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key       # 選配：有就啟用 OpenAI 對話 + 圖片生成
OPENAI_MODEL=gpt-4o-mini             # 模型：gpt-4o-mini / gpt-4o / o1

# ── 工作目錄 ─────────────────────────────────────────────────
AI_BOT_WORKSPACE=.

# ── 排程（選配）───────────────────────────────────────────────
NEWS_SCHEDULE_CRON=0 9 * * *
NEWS_TIMEZONE=Asia/Taipei
TELEGRAM_CHAT_ID=your_chat_id
