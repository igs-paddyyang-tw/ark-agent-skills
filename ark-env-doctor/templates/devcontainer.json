{
  "name": "${PROJECT_NAME} Dev",
  "build": { "dockerfile": "Dockerfile" },
  "customizations": {
    "vscode": {
      "settings": { "python.defaultInterpreterPath": "/usr/local/bin/python" },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "golang.go"
      ]
    }
  },
  "postCreateCommand": "pip install -r requirements.txt || true",
  "remoteUser": "vscode"
}
